__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/
.DS_Store

# Per-run artifacts a pack should never check in (rigs hold these)
.planning/
.tmux/

# Harness-materialized pack overlays / skills (regenerated by
# `po packs install` / materialize_packs; the canonical sources live in
# each pack's overlay/ dir, so the materialized copies are per-environment).
.claude/packs/
.claude/skills/
/CLAUDE-po-director.md
/CLAUDE-software-dev.md

# Per-pack uv lockfiles (editable dev installs don't need them committed).
parent/uv.lock
wts/uv.lock
.beads/embeddeddolt/
.beads/dolt/
.beads/dolt-server.*

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
